# ─────────────────────────────────────────────
# 数据集 — 整个 data/ 目录都不上传
# ─────────────────────────────────────────────
data/*
!data/.gitkeep
!data/README.md

# 兜底：任何位置的 token 二进制都不上传
*.bin

# ─────────────────────────────────────────────
# 模型权重 — checkpoints/ 下排除大文件
# 但保留训练配置文件（小 JSON，用于展示训练参数）
# ─────────────────────────────────────────────
checkpoints/*
!checkpoints/.gitkeep
!checkpoints/train_config.json
!checkpoints/README.md

# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ─────────────────────────────────────────────
# 虚拟环境
# ─────────────────────────────────────────────
venv/
env/
.venv/

# ─────────────────────────────────────────────
# IDE
# ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─────────────────────────────────────────────
# Jupyter
# ─────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─────────────────────────────────────────────
# 操作系统
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────
# Claude Code（仅本地使用，不上传）
# ─────────────────────────────────────────────
CLAUDE.md

# ─────────────────────────────────────────────
# 日志和实验追踪
# ─────────────────────────────────────────────
*.log
wandb/
runs/
