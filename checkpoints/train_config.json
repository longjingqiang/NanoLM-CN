{
  "data_dir": "data/processed_0.5M",
  "output_dir": "checkpoints",
  "tokenizer_path": "checkpoints/tokenizer_0.5M",
  "model_preset": "small",
  "max_iters": 35000,
  "batch_size": 64,
  "grad_accum": 2,
  "seq_len": 512,
  "lr": 0.0001,
  "lr_min": 1e-05,
  "warmup_iters": 2000,
  "lr_decay_iters": 45000,
  "weight_decay": 0.1,
  "beta1": 0.9,
  "beta2": 0.95,
  "grad_clip": 1.0,
  "early_stop_patience": 5,
  "early_stop_min_delta": 0.0001,
  "use_amp": true,
  "amp_dtype": "bf16",
  "use_grad_checkpoint": true,
  "compile_model": false,
  "log_interval": 50,
  "eval_interval": 500,
  "save_interval": 2000,
  "eval_iters": 100,
  "keep_checkpoints": 3,
  "seed": 42,
  "num_workers": 2,
  "pin_memory": true
}